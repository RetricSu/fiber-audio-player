{
  "name": "fiber-audio-player",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --filter . --filter ./backend dev:app",
    "dev:web": "next dev --turbopack",
    "dev:api": "pnpm -C backend dev",
    "dev:app": "next dev --turbopack",
    "build": "pnpm -r --filter . --filter ./backend --filter ./apps/cli build:app",
    "build:vercel": "next build",
    "build:web": "next build",
    "build:api": "pnpm -C backend build",
    "build:app": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "pnpm -r --filter . --filter ./backend typecheck:app",
    "typecheck:app": "tsc --noEmit",
    "typecheck:web": "tsc --noEmit",
    "typecheck:api": "pnpm -C backend typecheck"
  },
  "dependencies": {
    "@fiber-pay/sdk": "0.2.0",
    "hls.js": "^1.6.13",
    "motion": "^12.4.7",
    "next": "15.5.12",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
