# Recipient Fiber node public key (podcast owner who receives payments)
# This is a 33-byte compressed secp256k1 pubkey in hex format.
# Deployers MUST set this to the podcast owner's Fiber node pubkey.
NEXT_PUBLIC_RECIPIENT_PUBKEY=02b6d4e3ab86a2ca2fad6fae0ecb2e1e559e0b911939872a90abdda6d20302be71

# Recipient Fiber node multiaddr used for automatic peer bootstrap when listener node has no bootnode peers.
# Example format: /ip4/127.0.0.1/tcp/8228/p2p/Qm...
NEXT_PUBLIC_RECIPIENT_MULTIADDR=/ip4/18.162.235.225/tcp/8119/p2p/QmXen3eUHhywmutEzydCsW4hXBoeVmdET2FJvMX69XJ1Eo

# Payment tick interval in milliseconds (default 10000 = 10 seconds)
NEXT_PUBLIC_PAYMENT_INTERVAL_MS=10000
