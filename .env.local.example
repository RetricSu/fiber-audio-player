# Backend base URL (Hono API server)
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:8787

# Bootnode multiaddr — used to auto-connect the user's Fiber node to the network.
# This is NOT the payment recipient. Payments route through the network to reach
# the developer node (whose pubkey is auto-fetched from backend /node-info).
NEXT_PUBLIC_BOOTNODE_MULTIADDR=/ip4/54.179.226.154/tcp/8228/p2p/Qmes1EBD4yNo9Ywkfe6eRw9tG1nVNGLDmMud1xJMsoYFKy

# How many seconds of audio to purchase per invoice (default 30).
# Each click of play (or auto-extend) buys this many seconds at the backend's
# configured price-per-second.
NEXT_PUBLIC_STREAM_CHUNK_SECONDS=30
