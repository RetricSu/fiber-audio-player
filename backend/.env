PORT=8787

# Fiber RPC URL — the developer/content-owner node
FIBER_RPC_URL=http://127.0.0.1:8229

# Price per second of audio in shannon (1 CKB = 100_000_000 shannon)
# Default: 10000 shannon = 0.0001 CKB
PRICE_PER_SECOND_SHANNON=10000

# Invoice currency (Fibb = mainnet, Fibt = testnet, Fibd = dev)
INVOICE_CURRENCY=Fibt

# Invoice expiry in seconds
INVOICE_EXPIRY_SEC=600

# Hash algorithm for hold invoice payment_hash generation.
# Accepted values: CkbHash/ckb_hash or Sha256/sha256
INVOICE_HASH_ALGORITHM=Sha256

# Directory containing pre-generated encrypted HLS artifacts
HLS_DIR=../media/hls

# Must match ffmpeg -hls_time in the generate script
HLS_SEGMENT_DURATION_SEC=6

# Stream authorization token TTL in seconds
STREAM_AUTH_TTL_SEC=300

ADMIN_API_KEY=1111
